# Copy this file to ".env" and fill in your keys.

# Required: your Anthropic API key (get it at https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: enables real web search in the research step (https://tavily.com/, free tier).
# If left empty, the agent still runs but skips live web search.
TAVILY_API_KEY=
